// DSH Landing — Full Prisma Schema
// Covers: Auth, Films, Studio, Academy, Articles, Events, Impact, Donations, Subscriptions

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────
// NextAuth Models
// ─────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────────────────────
// Users & Auth
// ─────────────────────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(USER)
  adminRole     AdminRole?

  // Profile fields
  hasDonorBadge Boolean @default(false)
  status        String  @default("active") // active | inactive | suspended | cancelled
  lastActive    DateTime?

  // Relations
  accounts      Account[]
  sessions      Session[]
  subscriptions Subscription[]
  donations     Donation[]
  permissions   AdminPermission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdminPermission {
  id      String @id @default(cuid())
  userId  String
  module  String // social_media | academy | films | impact
  actions String[] // add | edit | delete

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, module])
}

// ─────────────────────────────────────────────────────────────
// Films
// ─────────────────────────────────────────────────────────────

enum FilmStage {
  DEVELOPMENT
  PRODUCTION
  POST_PRODUCTION
  FESTIVALS
  DISTRIBUTION
  IMPACT
}

enum FilmForm {
  DOCUMENTARY
  FICTION
}

enum FilmFormat {
  FEATURE
  SHORT
  SERIES
}

model Film {
  id   String @id @default(cuid())
  slug String @unique

  // Multilingual JSON: { en: "", pt: "", ar: "" }
  title            Json
  logline          Json
  synopsisShort    Json
  synopsisLong     Json
  editorialContext  Json

  stage      FilmStage @default(DEVELOPMENT)
  form       FilmForm  @default(DOCUMENTARY)
  format     FilmFormat @default(FEATURE)
  themes     String[]
  accessMode String    @default("public") // public | request_only

  // Credits (flat fields — single set per film)
  creditDirection    String @default("")
  creditProduction   String @default("")
  creditCoProduction String @default("")
  creditYear         String @default("")
  creditDuration     String @default("")
  creditLanguage     String @default("")
  creditCountry      String @default("")

  // Media URLs
  trailerUrl   String @default("")
  thumbnailUrl String @default("")
  posterUrl    String @default("")

  // Publishing
  status     String  @default("draft") // draft | published | archived
  isFeatured Boolean @default(false)

  // Relations
  festivals  FilmFestival[]
  screenings FilmScreening[]
  pressQuotes FilmPressQuote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FilmFestival {
  id        String  @id @default(cuid())
  filmId    String
  name      String
  year      String
  award     String?
  selection String?

  film Film @relation(fields: [filmId], references: [id], onDelete: Cascade)
}

model FilmScreening {
  id       String @id @default(cuid())
  filmId   String
  event    String
  date     String
  location String
  type     String // cinema | festival | community | educational | online

  film Film @relation(fields: [filmId], references: [id], onDelete: Cascade)
}

model FilmPressQuote {
  id     String @id @default(cuid())
  filmId String
  source String
  quote  String @db.Text

  film Film @relation(fields: [filmId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────────
// Studio
// ─────────────────────────────────────────────────────────────

enum StudioFormat {
  DOCUSERIES
  VIDEOCAST
  PODCAST
  SERIES
  OTHER
}

model StudioItem {
  id   String @id @default(cuid())
  slug String @unique

  // Multilingual JSON
  title           Json
  description     Json
  synopsisShort   Json
  synopsisLong    Json
  editorialContext Json

  format       StudioFormat @default(PODCAST)
  studioStatus String       @default("ongoing") // ongoing | complete | upcoming
  themes       String[]

  // Credits (flat)
  creditProduction   String @default("")
  creditCoProduction String @default("")
  creditHostsCreators String @default("")
  creditPartners     String @default("")
  creditYear         String @default("")
  creditLanguage     String @default("")

  // Media
  thumbnailUrl String @default("")
  coverUrl     String @default("")

  // Publishing
  status String @default("draft") // draft | published | archived

  // Related content (stored as ID arrays)
  relatedFilmIds    String[]
  relatedArticleIds String[]

  // Relations
  episodes      StudioEpisode[]
  platformLinks StudioPlatformLink[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StudioEpisode {
  id           String @id @default(cuid())
  studioItemId String

  // Multilingual JSON
  title       Json
  description Json

  duration String @default("")
  season   Int?
  episode  Int?

  studioItem StudioItem @relation(fields: [studioItemId], references: [id], onDelete: Cascade)
}

model StudioPlatformLink {
  id           String @id @default(cuid())
  studioItemId String
  platform     String
  url          String

  studioItem StudioItem @relation(fields: [studioItemId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────────
// Academy
// ─────────────────────────────────────────────────────────────

enum AcademyType {
  COURSE
  WORKSHOP
  TOOLKIT
  RESOURCE
  MENTORSHIP
}

enum AcademyFormat {
  ONLINE
  IN_PERSON
  HYBRID
  SELF_PACED
  DOWNLOADABLE
}

model AcademyProgram {
  id   String @id @default(cuid())
  slug String @unique

  // Multilingual JSON
  title           Json
  description     Json
  whoLeads        Json
  whoItsFor       Json
  scholarshipNote Json
  howToJoin       Json

  type           AcademyType   @default(COURSE)
  format         AcademyFormat @default(ONLINE)
  objectives     String[]      // Learning objectives
  duration       String        @default("")
  dates          String        @default("")

  // Pricing
  isFree Boolean @default(true)
  price  Float?

  // Media
  thumbnailUrl String @default("")

  // Stats
  enrolledCount  Int @default(0)
  completionRate Float @default(0)

  // Publishing
  status String @default("draft") // draft | published | archived

  // Related content
  relatedFilmIds   String[]
  relatedStudioIds String[]

  // Relations
  resources AcademyResource[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AcademyResource {
  id        String @id @default(cuid())
  programId String
  title     String
  type      String // pdf | link | toolkit
  url       String

  program AcademyProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────────
// Articles / Read
// ─────────────────────────────────────────────────────────────

model Article {
  id   String @id @default(cuid())
  slug String @unique

  // Multilingual JSON
  title    Json
  excerpt  Json
  body     Json // Array of ArticleBlock objects

  tag              String @default("")
  date             DateTime @default(now())
  mainImage        String @default("")
  mainImageCaption String @default("")
  mainImageCredit  String @default("")

  // Author (embedded as JSON — single author per article)
  author Json // { name, avatar, bio }

  // Gallery (JSON array)
  gallery Json @default("[]") // [{ id, url, caption, credit }]

  // SEO
  seoMetaDescription String @default("")
  seoSocialShareImage String @default("")

  // Publishing
  status        String    @default("draft") // draft | published | scheduled | archived
  scheduledDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────
// Events
// ─────────────────────────────────────────────────────────────

model Event {
  id   String @id @default(cuid())
  slug String @unique

  // Multilingual JSON
  title       Json
  excerpt     Json
  description Json

  tag       String @default("")
  startDate DateTime
  endDate   DateTime
  mainImage String @default("")
  address   String @default("")

  // Coordinates (nullable)
  lat Float?
  lng Float?

  // Tickets
  ticketType  String @default("free") // free | paid
  ticketUrl   String @default("")
  ticketPrice Float?

  // Status & capacity
  status    String @default("upcoming") // upcoming | past | cancelled | sold_out
  rsvpCount Int    @default(0)
  capacity  Int?

  // Relations
  partners EventPartner[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EventPartner {
  id      String @id @default(cuid())
  eventId String
  name    String
  logo    String @default("")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────────
// Impact
// ─────────────────────────────────────────────────────────────

model ImpactStory {
  id String @id @default(cuid())

  // Multilingual JSON
  title       Json
  description Json

  imageUrl     String  @default("")
  linkedFilm   String? // Film ID reference
  linkedCourse String? // AcademyProgram ID reference
  status       String  @default("draft") // draft | published

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ImpactStat {
  id     String @id @default(cuid())
  label  String
  value  Float
  suffix String @default("")
  icon   String @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────
// Subscriptions & Donations
// ─────────────────────────────────────────────────────────────

model Subscription {
  id     String @id @default(cuid())
  userId String

  plan        String // monthly | yearly
  amount      Float
  status      String @default("active") // active | cancelled | expired | past_due
  startDate   DateTime
  endDate     DateTime
  nextBilling DateTime

  // Stripe
  stripeSubscriptionId String? @unique
  stripeCustomerId     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Donation {
  id     String @id @default(cuid())
  userId String?

  donorName  String
  donorEmail String
  amount     Float
  isGuest    Boolean @default(false)
  message    String  @default("") @db.Text

  // Stripe
  stripePaymentId String? @unique

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────
// Email Forwarding Rules (Settings)
// ─────────────────────────────────────────────────────────────

model EmailForwardingRule {
  id      String   @id @default(cuid())
  trigger String   // new_lead | new_subscription | new_donation
  emails  String[]
  enabled Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
